rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdminEmail() {
      return isAuthenticated() && 
        request.auth.token.email in ['govind@cavacham.com', 'contact@cavacham.com'];
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        isAdminEmail() || 
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin'
      );
    }
    
    // Users collection - matches your console structure
    match /users/{userId} {
      allow read: if true; // Allow reading user profiles for display purposes
      allow create: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow update: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAdmin();
      
      // User addresses subcollection - FIXED: This is where addresses are actually stored
      match /addresses/{addressId} {
        allow read, write: if isOwner(userId) || isAdmin();
        allow create: if isAuthenticated() && (isOwner(userId) || isAdmin());
        allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
        allow delete: if isAuthenticated() && (isOwner(userId) || isAdmin());
      }
      
      // User orders subcollection - for user-specific orders
      match /orders/{orderId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // User preferences subcollection
      match /preferences/{prefId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // User notifications subcollection
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // User devices/FCM tokens
      match /devices/{deviceId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // User cart items subcollection
      match /cart/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
      
      // User wishlist subcollection
      match /wishlist/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // User Profiles collection - used by the CleverTap Sample App
    match /userProfiles/{userId} {
      allow read: if true; // Allow reading user profiles for display purposes
      allow create: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow update: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Products/Crystals collection - public read access
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Crystals collection (your main products)
    match /crystals/{crystalId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Services collection - public read, admin write
    match /services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Service categories collection
    match /service_categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Service bookings - user can read/create their own, admin can manage all
    match /service_bookings/{bookingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // Service reviews - public read, authenticated write for own reviews
    match /service_reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // Service availability/slots - public read, admin write
    match /service_availability/{availabilityId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Practitioner profiles - public read, admin write
    match /practitioners/{practitionerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Categories collection
    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Global cart collection (if used separately from user subcollections)
    match /cart/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      // Cart items subcollection
      match /items/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Global orders collection - user-specific access
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    // REMOVED: Global addresses collection since addresses are stored as subcollections
    // Addresses are now properly handled in users/{userId}/addresses/{addressId}
    
    // Global wishlist collection (if used separately)
    match /wishlist/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
      
      match /items/{itemId} {
        allow read, write: if isOwner(userId) || isAdmin();
      }
    }
    
    // Reviews collection - public read, authenticated write
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
    }
    
    // Payment and Transaction Management
    match /payments/{paymentId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Coupons and Discounts
    match /coupons/{couponId} {
      allow read: if isAuthenticated(); // Users need to read to apply coupons
      allow write: if isAdmin();
    }
    
    match /discounts/{discountId} {
      allow read: if true; // Public read for promotional displays
      allow write: if isAdmin();
    }
    
    // Inventory Management
    match /inventory/{inventoryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /stock_movements/{movementId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Shipping and Delivery
    match /shipping/{shippingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }
    
    match /delivery_tracking/{trackingId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow write: if isAdmin();
    }
    
    // Customer Support
    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated() && 
        request.resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /support_messages/{messageId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // App Content Management
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /promotions/{promotionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /app_content/{contentId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /faq/{faqId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /help_articles/{articleId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Legal and Compliance
    match /terms_and_conditions/{versionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /privacy_policy/{versionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Notifications and Messaging
    match /global_notifications/{notificationId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /email_templates/{templateId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    match /push_notifications/{notificationId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }
    
    // Social and Community Features
    match /user_feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /app_ratings/{ratingId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || isAdmin()
      );
      allow delete: if isAdmin();
    }
    
    match /referrals/{referralId} {
      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid || 
        resource.data.referredUserId == request.auth.uid ||
        isAdmin()
      );
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Search and Analytics
    match /search_history/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }
    
    match /user_activity/{activityId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Content Moderation
    match /reported_content/{reportId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    match /blocked_users/{blockId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated() && 
        request.resource.data.blockedBy == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // App configuration collections - public read
    match /app_settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Public data collections
    match /purposes/{purposeId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /chakras/{chakraId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /featured/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /newLaunches/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Featured services
    match /featured_services/{serviceId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Service promotions/offers
    match /service_offers/{offerId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Admin-only collections
    match /analytics/{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /logs/{document=**} {
      allow read, write: if isAdmin();
    }
    
    match /adminSettings/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Service analytics (admin only)
    match /service_analytics/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // Audit and Compliance
    match /audit_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /data_exports/{exportId} {
      allow read, write: if isAdmin();
    }
    
    // App Version Management
    match /app_versions/{versionId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /feature_flags/{flagId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Temporary/Cache Collections
    match /temp_data/{document=**} {
      allow read, write: if isAuthenticated();
      // Note: Set TTL on these documents in Firestore console
    }
    
    match /cache/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
      // Note: Set TTL on these documents in Firestore console
    }
  }
}

// Firebase Storage Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper functions for Storage
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isAdminEmail() {
      return isAuthenticated() && 
        request.auth.token.email in ['govind@cavacham.com', 'contact@cavacham.com'];
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        isAdminEmail() || 
        request.auth.token.admin == true ||
        request.auth.token.role == 'admin'
      );
    }
    
    function isValidImageFile() {
      return resource.contentType.matches('image/.*') &&
             resource.size < 10 * 1024 * 1024; // 10MB limit
    }
    
    // Profile Images - users can upload their own profile images
    match /profile_images/{userId}.{extension} {
      allow read: if true; // Public read for profile images
      allow write: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      ) && isValidImageFile();
      allow delete: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
    }
    
    // Product Images - admin only
    match /product_images/{imageId} {
      allow read: if true; // Public read for product images
      allow write: if isAdmin() && isValidImageFile();
      allow delete: if isAdmin();
    }
    
    // Service Images - admin only
    match /service_images/{imageId} {
      allow read: if true; // Public read for service images
      allow write: if isAdmin() && isValidImageFile();
      allow delete: if isAdmin();
    }
    
    // Banner Images - admin only
    match /banner_images/{imageId} {
      allow read: if true; // Public read for banner images
      allow write: if isAdmin() && isValidImageFile();
      allow delete: if isAdmin();
    }
    
    // User Generated Content (reviews, feedback images)
    match /user_content/{userId}/{imageId} {
      allow read: if true; // Public read for user content
      allow write: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      ) && isValidImageFile();
      allow delete: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
    }
    
    // Admin uploads
    match /admin_uploads/{document=**} {
      allow read: if isAdmin();
      allow write: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Temporary uploads (with TTL)
    match /temp_uploads/{userId}/{document=**} {
      allow read, write: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
      allow delete: if isAuthenticated() && (
        isOwner(userId) || isAdmin()
      );
    }
  }
} 